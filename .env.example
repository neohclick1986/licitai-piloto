# =============================================================================
# LicitaI Piloto - Environment variables
# Copie para .env e preencha com seus valores do Supabase
# =============================================================================

# Ambiente
ENVIRONMENT=dev
LOG_LEVEL=INFO
DEBUG=true

# Supabase (obtenha em https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=https://SEU-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
# JWT secret do projeto (Settings → API → JWT Settings) — usado para validar tokens de autenticação
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui
# Connection string direta do Postgres (Settings -> Database -> Connection string -> URI)
# Formato: postgresql+asyncpg://postgres:SENHA@db.SEU-REF.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql+asyncpg://postgres:SUA-SENHA@db.SEU-REF.supabase.co:5432/postgres

# Segurança
SECRET_KEY=mude-isso-em-producao-min-32-caracteres-aqui-12345
JWT_AUDIENCE=authenticated
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS (domínio do frontend)
CORS_ORIGINS=["http://localhost:3000"]

# LLM Provider
# Opções: openai | ollama
LLM_DEFAULT_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Para usar Ollama local (grátis, sem cloud)
# LLM_DEFAULT_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Features
ENABLE_RLS=true
ENABLE_AI=true
AI_REQUIRE_HUMAN_APPROVAL=true
